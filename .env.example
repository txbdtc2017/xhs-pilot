# ===== 应用 =====
NODE_ENV=development
# 监听端口请通过 `PORT=3000 npm run dev` 或 `PORT=3000 docker compose up -d --build` 注入，不要写进 .env
# 当前未被运行时读取，暂保留为未来认证/签名相关扩展字段
APP_SECRET=your-random-secret

# ===== 数据库 =====
# 本地开发用 localhost，Docker Compose 中会覆盖为 postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=xhs_pilot
DB_PASSWORD=change-me
DB_NAME=xhs_pilot
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ===== Redis =====
# 本地开发用 localhost，Docker Compose 中会覆盖为 redis
REDIS_URL=redis://localhost:6379

# ===== LLM（支持 OpenAI-compatible 与 Anthropic Messages） =====
# 可选值：openai | anthropic-messages
# 如果使用 Kimi coding / Claude Code 风格的 Anthropic 兼容接口，请改成 anthropic-messages
# anthropic-messages 模式下，LLM_BASE_URL / VISION_BASE_URL 支持带 `/v1` 或不带 `/v1` 两种写法，运行时会自动规范化
# Kimi coding 示例：
# LLM_PROTOCOL=anthropic-messages
# LLM_BASE_URL=https://api.kimi.com/coding/
# LLM_MODEL_ANALYSIS=kimi-code
# LLM_MODEL_GENERATION=kimi-code
# LLM_MODEL_VISION=kimi-code
# VISION_PROTOCOL=${LLM_PROTOCOL}
# VISION_BASE_URL=${LLM_BASE_URL}
# `kimi-code` 是推荐别名；`k2p5` 仍兼容 legacy 配置
LLM_PROTOCOL=openai
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_ANALYSIS=gpt-4o
LLM_MODEL_GENERATION=gpt-4o
LLM_MODEL_VISION=gpt-4o
VISION_PROTOCOL=${LLM_PROTOCOL}
VISION_API_KEY=${LLM_API_KEY}
VISION_BASE_URL=${LLM_BASE_URL}

# ===== 图片生成（可选，支持 OpenAI-Compatible 与 Google Banana） =====
# 未完整配置时，文本生成链路保持可用，/create 的图片工作区会停留在“未启用图片能力”
# 如果使用 Docker Compose，建议把 Google service account JSON 放到仓库根目录的 `.credentials/google-vertex.json`
# 本机直跑和容器内都使用同一条相对路径，不要写宿主机绝对路径到这里
IMAGE_PROTOCOL=openai
IMAGE_API_KEY=${LLM_API_KEY}
IMAGE_BASE_URL=${LLM_BASE_URL}
IMAGE_MODEL=gpt-image-1
IMAGE_GOOGLE_CREDENTIALS_PATH=./.credentials/google-vertex.json
IMAGE_GOOGLE_PROJECT_ID=
IMAGE_GOOGLE_LOCATION=global
IMAGE_GOOGLE_MODEL=gemini-3-pro-image-preview

# ===== Embedding（可选增强能力，仍使用 OpenAI-compatible 接口） =====
# 任意关键项缺失时都会回退到 lexical-only 检索模式，样本可正常分析与生成，但不会做语义向量检索
# 本轮 Kimi Coding Anthropic 兼容不涉及 EMBEDDING_* 语义调整
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
# 当前未被运行时读取，暂保留为向量维度兼容说明
EMBEDDING_DIMENSIONS=1536

# ===== 图片存储 =====
# Phase 6 官方只支持 local；s3/r2 属于后续 roadmap
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads

# ===== 运行参数 =====
MAX_UPLOAD_SIZE_MB=10
# 当前未被运行时读取，暂保留为未来队列并发控制字段
ANALYSIS_CONCURRENCY=2
LOG_LEVEL=info
