# ===== 应用 =====
NODE_ENV=development
APP_URL=http://localhost:17789
APP_SECRET=your-random-secret

# ===== 数据库 =====
# 本地开发用 localhost，Docker Compose 中会覆盖为 postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=xhs_pilot
DB_PASSWORD=change-me
DB_NAME=xhs_pilot
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ===== Redis =====
# 本地开发用 localhost，Docker Compose 中会覆盖为 redis
REDIS_URL=redis://localhost:6379

# ===== LLM（支持任意 OpenAI-compatible API） =====
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_ANALYSIS=gpt-4o
LLM_MODEL_GENERATION=gpt-4o
LLM_MODEL_VISION=gpt-4o

# ===== Embedding（可单独切换 provider / model） =====
EMBEDDING_API_KEY=${LLM_API_KEY}
EMBEDDING_BASE_URL=${LLM_BASE_URL}
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ===== 图片存储 =====
# Phase 6 官方只支持 local；s3/r2 属于后续 roadmap
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads

# ===== 运行参数 =====
MAX_UPLOAD_SIZE_MB=10
ANALYSIS_CONCURRENCY=2
LOG_LEVEL=info
