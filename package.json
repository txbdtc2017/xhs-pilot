{
  "name": "xhs-pilot",
  "version": "0.2.1",
  "private": true,
  "scripts": {
    "dev": "node --import tsx scripts/run-next.ts dev",
    "build": "next build",
    "start": "node --import tsx scripts/run-next.ts start",
    "lint": "eslint",
    "test": "node --test --import tsx $(rg --files | rg '\\.test\\.ts$' | tr '\\n' ' ')",
    "check": "npm run lint && npm run test && npm run build",
    "worker:dev": "sh scripts/with-env.sh tsx watch src/worker.ts",
    "worker:start": "sh scripts/with-env.sh tsx src/worker.ts",
    "db:migrate": "sh scripts/with-env.sh node-pg-migrate up",
    "db:migrate:down": "sh scripts/with-env.sh node-pg-migrate down",
    "embeddings:backfill": "sh scripts/with-env.sh tsx scripts/backfill-embeddings.ts",
    "seed": "sh scripts/with-env.sh sh scripts/seed.sh"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.63",
    "@ai-sdk/openai": "^3.0.47",
    "ai": "^6.0.134",
    "bullmq": "^5.71.0",
    "ioredis": "^5.10.1",
    "next": "16.2.1",
    "pg": "^8.20.0",
    "pgvector": "^0.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "node-pg-migrate": "^8.0.4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
